{
  "private": true,
  "name": "zenixui",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "predev": "npx tsx scripts/generate-raw.ts",
    "dev": "npm run dev --workspace=apps/website",
    "prebuild": "npx tsx scripts/generate-raw.ts",
    "build": "npm run build --workspace=apps/website",
    "lint": "npm run lint --workspace=apps/website",
    "test:export": "npx tsx scripts/test-export.ts"
  },
  "devDependencies": {
    "ignore-styles": "^5.0.1",
    "playwright": "^1.61.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.23.1"
  }
}
